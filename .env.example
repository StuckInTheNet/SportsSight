# === Database ===
DATABASE_URL=postgresql+asyncpg://sportssight:sportssight@localhost:5432/sportssight
DATABASE_URL_SYNC=postgresql://sportssight:sportssight@localhost:5432/sportssight

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# === Device ===
# Options: auto, mps, cuda, cpu
DEVICE=auto

# === Video Processing ===
# Max concurrent video streams for real-time processing
MAX_STREAMS=4
# Target FPS for inference (lower = less GPU load)
INFERENCE_FPS=15

# === Model Paths ===
YOLO_MODEL_PATH=data/models/yolov8x.pt
POSE_MODEL_PATH=data/models/rtmpose-l.pth
REID_MODEL_PATH=data/models/osnet_x1_0.pth

# === NBA API (optional, for data acquisition) ===
# NBA_API_DELAY=1.0
